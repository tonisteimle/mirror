  "instances": [
    {
      "children": [
        {
          "component": "Input",
          "name": "search",
          "properties": [
            {
              "name": "content",
              "type": "Property",
              "values": [
                "Suchen...",
              ],
            },
          ],
          "type": "Instance",
        },
        {
          "children": [
            {
              "children": [
                {
                  "component": "Item",
                  "name": null,
                  "properties": [
                    {
                      "name": "item",
                      "type": "Property",
                      "values": [
                        "name",
                      ],
                    },
                  ],
                  "type": "Instance",
                },
              ],
              "component": "item",
              "name": null,
              "properties": [
                {
                  "name": "filteredItems",
                  "type": "Property",
                },
              ],
              "type": "Instance",
            },
          ],
          "component": "List",
          "name": "results",
          "type": "Instance",
        },
        {
          "component": "Text",
          "name": "status",
          "type": "Instance",
        },
      ],
      "component": "Container",
      "name": null,
      "type": "Instance",
    },
  ],
  "javascript": {
    "code": "let items = []
let filteredItems = []

search.oninput = () => {
    const query = search.value.toLowerCase()
    filteredItems = items.filter(i =>
        i.name.toLowerCase().includes(query)
    )
    status.text = \`\${filteredItems.length} Ergebnisse\`
    update()
}

fetch('/api/items')
    .then(r => r.json())
    .then(data => {
        items = data
        filteredItems = data
        update()
    })",
    "type": "JavaScript",
  },
  "type": "Program",
}
`;

