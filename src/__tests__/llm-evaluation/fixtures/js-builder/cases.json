{
  "name": "JS Builder Test Suite",
  "description": "Tests for JavaScript Builder API to Mirror DSL conversion",
  "pipeline": "js-builder",
  "version": "1.0",
  "notes": "LLM generates JavaScript-like component calls that transform to Mirror DSL",
  "cases": [
    {
      "id": "button-simple",
      "description": "Einfacher Button via JS Builder",
      "pipeline": "js-builder",
      "severity": "critical",
      "input": {
        "prompt": "Ein blauer Button mit Text 'Klick mich'"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "llmQuality": true,
        "contains": {
          "components": ["Button"],
          "text": ["Klick"]
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["button", "simple"]
    },
    {
      "id": "card-with-content",
      "description": "Card mit verschachteltem Content",
      "pipeline": "js-builder",
      "severity": "critical",
      "input": {
        "prompt": "Eine Card mit Titel 'Willkommen' und einem Button"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "llmQuality": true,
        "contains": {
          "components": ["Card", "Button"],
          "text": ["Willkommen"]
        },
        "structure": {
          "minDepth": 2
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["card", "nested"],
      "skip": true,
      "skipReason": "JS→Mirror converter issue: 'mb' (margin-bottom) not supported as Mirror shorthand"
    },
    {
      "id": "row-with-items",
      "description": "Horizontale Reihe mit mehreren Items",
      "pipeline": "js-builder",
      "severity": "critical",
      "input": {
        "prompt": "Eine horizontale Reihe mit drei Buttons: Ja, Nein, Abbrechen"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "contains": {
          "components": ["Button"],
          "text": ["Ja", "Nein", "Abbrechen"]
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["layout", "horizontal", "multiple"]
    },
    {
      "id": "input-with-label",
      "description": "Input mit Label",
      "pipeline": "js-builder",
      "severity": "important",
      "input": {
        "prompt": "Ein Eingabefeld mit Label 'Email' darüber"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "contains": {
          "text": ["Email"]
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["input", "form"],
      "skip": true,
      "skipReason": "JS→Mirror converter issue: Column(null, [...]) loses children"
    },
    {
      "id": "icon-button",
      "description": "Button mit Icon",
      "pipeline": "js-builder",
      "severity": "important",
      "input": {
        "prompt": "Ein Button mit einem Herz-Icon und Text 'Like'"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "contains": {
          "components": ["Button"],
          "text": ["Like"]
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["button", "icon"]
    },
    {
      "id": "styled-text",
      "description": "Gestylter Text",
      "pipeline": "js-builder",
      "severity": "normal",
      "input": {
        "prompt": "Ein großer fetter Titel 'Dashboard'"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "contains": {
          "text": ["Dashboard"]
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["text", "typography"]
    },
    {
      "id": "list-items",
      "description": "Liste mit mehreren Items",
      "pipeline": "js-builder",
      "severity": "normal",
      "input": {
        "prompt": "Eine Liste mit Items: Profil, Einstellungen, Logout"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "contains": {
          "text": ["Profil", "Einstellungen", "Logout"]
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["list", "multiple"]
    },
    {
      "id": "complex-form",
      "description": "Komplexes Formular",
      "pipeline": "js-builder",
      "severity": "edge-case",
      "input": {
        "prompt": "Ein Login-Formular mit Email-Feld, Passwort-Feld und Submit-Button"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "contains": {
          "components": ["Button"],
          "text": ["Email", "Passwort"]
        },
        "structure": {
          "minDepth": 2
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["form", "complex"]
    },
    {
      "id": "alert-box",
      "description": "Hinweisbox mit Icon",
      "pipeline": "js-builder",
      "severity": "normal",
      "input": {
        "prompt": "Eine gelbe Warnhinweis-Box mit Ausrufezeichen-Icon und Text"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "notContains": ["undefined", "error"]
      },
      "tags": ["alert", "warning", "icon"]
    },
    {
      "id": "stats-card",
      "description": "Statistik-Karte",
      "pipeline": "js-builder",
      "severity": "normal",
      "input": {
        "prompt": "Eine Statistik-Karte mit großer Zahl '1,234' und Label 'Benutzer'"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "contains": {
          "components": ["Card"],
          "text": ["Benutzer"]
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["stats", "card", "number"]
    },
    {
      "id": "nav-menu",
      "description": "Navigations-Menü",
      "pipeline": "js-builder",
      "severity": "normal",
      "input": {
        "prompt": "Ein vertikales Navigationsmenü mit Icons: Home, Nachrichten, Einstellungen"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "contains": {
          "text": ["Home", "Nachrichten", "Einstellungen"]
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["navigation", "menu", "icons"]
    },
    {
      "id": "progress-indicator",
      "description": "Fortschrittsanzeige",
      "pipeline": "js-builder",
      "severity": "normal",
      "input": {
        "prompt": "Ein Fortschrittsbalken bei 75% mit Prozentanzeige"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "contains": {
          "text": ["75"]
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["progress", "percentage"]
    },
    {
      "id": "user-avatar-row",
      "description": "Benutzer-Zeile mit Avatar",
      "pipeline": "js-builder",
      "severity": "normal",
      "input": {
        "prompt": "Eine Zeile mit rundem Avatar, Name 'Max Mustermann' und Status-Badge 'Online'"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "contains": {
          "text": ["Max"]
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["user", "avatar", "status"]
    },
    {
      "id": "action-buttons",
      "description": "Action Button Gruppe",
      "pipeline": "js-builder",
      "severity": "normal",
      "input": {
        "prompt": "Drei Icon-Buttons horizontal: Bearbeiten (Stift), Löschen (Papierkorb), Teilen (Pfeil)"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "contains": {
          "components": ["Button"]
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["buttons", "icons", "actions"]
    },
    {
      "id": "empty-state-card",
      "description": "Empty State",
      "pipeline": "js-builder",
      "severity": "normal",
      "input": {
        "prompt": "Ein Empty State: Zentriert mit Icon, Titel 'Keine Daten' und Button 'Neu erstellen'"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "contains": {
          "text": ["Keine", "Daten"]
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["empty", "state", "centered"]
    }
  ]
}
