{
  "name": "React-Pivot Staged Test Suite",
  "description": "Tests for the Staged React-Pivot pipeline: LLM generates React, then deterministic transformation to Mirror DSL",
  "pipeline": "react-pivot-staged",
  "version": "1.0",
  "cases": [
    {
      "id": "simple-text",
      "description": "Ein Text 'Hello World'",
      "pipeline": "react-pivot-staged",
      "severity": "critical",
      "input": {
        "prompt": "Ein Text \"Hello World\""
      },
      "expect": {
        "parses": true,
        "validates": true,
        "llmQuality": true,
        "contains": {
          "components": ["Text"],
          "text": ["Hello World"]
        },
        "notContains": ["undefined", "error", "Error"]
      },
      "tags": ["basic", "text"]
    },
