      "input": {
        "prompt": "Ein Such-Icon"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "notContains": ["undefined", "error", "path-data"]
      },
      "tags": ["icon"],
      "notes": "LLM may generate Icon 'search', SearchIcon, or search-related component. All valid."
    },
    {
      "id": "token-usage",
      "description": "Button mit Token-Referenz",
      "pipeline": "nl-translation",
      "severity": "important",
      "input": {
        "prompt": "Ein Button mit der Primärfarbe",
        "context": {
          "tokens": "$primary: #3B82F6"
        }
      },
      "expect": {
        "parses": true,
        "validates": true,
        "contains": {
          "components": ["Button"],
          "tokens": ["$primary"]
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["button", "token"]
    },
