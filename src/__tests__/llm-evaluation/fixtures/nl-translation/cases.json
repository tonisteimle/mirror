{
  "name": "NL Translation Test Suite",
  "description": "Tests for natural language to Mirror DSL translation",
  "pipeline": "nl-translation",
  "version": "1.0",
  "cases": [
    {
      "id": "button-simple",
      "description": "Ein blauer Button",
      "pipeline": "nl-translation",
      "severity": "critical",
      "input": {
        "prompt": "Ein blauer Button"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "llmQuality": true,
        "contains": {
          "components": ["Button"],
          "properties": ["bg"]
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["button", "color", "simple"]
    },
    {
      "id": "button-with-text",
      "description": "Ein grüner Button mit Text 'Speichern'",
      "pipeline": "nl-translation",
      "severity": "critical",
      "input": {
        "prompt": "Ein grüner Button mit Text 'Speichern'"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "contains": {
          "components": ["Button"],
          "text": ["Speichern"]
        },
        "notContains": ["undefined", "error"]
      },
      "tags": ["button", "text", "color"]
    },
