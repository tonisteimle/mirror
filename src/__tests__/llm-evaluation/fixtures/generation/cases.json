{
  "name": "Code Generation Test Suite",
  "description": "Tests for full Mirror code generation from prompts",
  "pipeline": "generation",
  "version": "1.1",
  "notes": "Testing with improved prompting that explicitly shows Mirror syntax vs CSS",
  "cases": [
    {
      "id": "login-form",
      "description": "Generiere ein Login-Formular",
      "pipeline": "generation",
      "severity": "critical",
      "input": {
        "prompt": "Erstelle ein Login-Formular mit Email, Passwort und einem Login-Button"
      },
      "expect": {
        "parses": true,
        "validates": true,
        "llmQuality": true,
        "contains": {
          "components": ["Button"]
        },
        "structure": {
          "minDepth": 2
        },
        "notContains": ["undefined", "error", "Error", "{", ":", "px"]
      },
      "tags": ["form", "auth", "complex"]
    },
    {
