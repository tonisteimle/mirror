  _animPropMap(name) {
    const map = {
      'opacity': 'opacity',
      'x-offset': 'translateX',
      'y-offset': 'translateY',
      'scale': 'scale',
      'scale-x': 'scaleX',
      'scale-y': 'scaleY',
      'rotate': 'rotate',
      'background': 'backgroundColor',
      'bg': 'backgroundColor',
      'color': 'color',
      'col': 'color',
      'width': 'width',
      'height': 'height',
      'padding': 'padding',
      'pad': 'padding',
      'radius': 'borderRadius',
      'rad': 'borderRadius',
    }
