// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Animations: Snapshot > sollte Fade dem Snapshot entsprechen 1`] = `"<div data-id="Row1" data-source-line="2" class="Row" style="display: inline-flex; flex-direction: column; gap: 16px;"><div data-id="Button1" data-state="default" class="Button" style="display: inline-block; padding: 12px; background-color: rgb(59, 130, 246); border-radius: 8px; color: white;"><button data-id="Button1" data-source-line="3" class="Button" type="button" style="background-color: rgb(59, 130, 246); color: white; border: medium; border-radius: 8px; padding: 12px; font-size: 13px; font-weight: 500; cursor: pointer; line-height: 1.4; display: inline-block;"></button></div></div><div data-id="Message1" data-source-line="3" class="Message" style="display: inline-flex; flex-direction: column;"></div>"`;

exports[`Animations: Snapshot > sollte Spinner dem Snapshot entsprechen 1`] = `"<div data-id="Spinner1" data-source-line="0" class="Spinner" style="display: inline-flex; flex-direction: column; width: 24px; max-width: 24px; flex-shrink: 0; height: 24px; max-height: 24px; border: 3px solid rgb(59, 130, 246); border-radius: 99px; animation: spin 1000ms ease-in-out infinite;"><div data-id="transparent1" data-source-line="0" class="transparent"></div></div>"`;
