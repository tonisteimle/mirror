// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Grid Layout: Snapshot > sollte Auto-fill dem Snapshot entsprechen 1`] = `"<div data-id="Grid1" data-source-line="0" class="Grid" style="display: grid; flex-direction: column; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px;"><div data-id="Item1" data-source-line="1" class="Item" style="display: inline-block; background-color: rgb(59, 130, 246); padding: 12px; color: rgb(165, 165, 165);">Item 1</div><div data-id="Item2" data-source-line="2" class="Item" style="display: inline-block; background-color: rgb(34, 197, 94); padding: 12px; color: rgb(165, 165, 165);">Item 2</div><div data-id="Item3" data-source-line="3" class="Item" style="display: inline-block; background-color: rgb(239, 68, 68); padding: 12px; color: rgb(165, 165, 165);">Item 3</div><div data-id="Item4" data-source-line="4" class="Item" style="display: inline-block; background-color: rgb(245, 158, 11); padding: 12px; color: rgb(165, 165, 165);">Item 4</div></div>"`;

exports[`Grid Layout: Snapshot > sollte Equal Columns dem Snapshot entsprechen 1`] = `"<div data-id="Grid1" data-source-line="0" class="Grid" style="display: grid; flex-direction: column; grid-template-columns: repeat(3, 1fr); gap: 16px;"><div data-id="Card1" data-source-line="1" class="Card" style="display: inline-flex; flex-direction: column; gap: 8px; padding: 16px; background-color: rgb(51, 51, 51); border-radius: 12px; color: rgb(165, 165, 165);"><span>Card 1</span></div><div data-id="Card2" data-source-line="2" class="Card" style="display: inline-flex; flex-direction: column; gap: 8px; padding: 16px; background-color: rgb(51, 51, 51); border-radius: 12px; color: rgb(165, 165, 165);"><span>Card 2</span></div><div data-id="Card3" data-source-line="3" class="Card" style="display: inline-flex; flex-direction: column; gap: 8px; padding: 16px; background-color: rgb(51, 51, 51); border-radius: 12px; color: rgb(165, 165, 165);"><span>Card 3</span></div></div>"`;
