// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Conditionals: Snapshot > sollte Block Conditional dem Snapshot entsprechen 1`] = `"<div data-id="Container1" data-source-line="2" class="Container" style="display: inline-flex; flex-direction: column; gap: 12px;"><button data-id="Button1" data-source-line="6" class="Button" type="button" style="background-color: rgb(34, 197, 94); color: rgb(165, 165, 165); border: medium; border-radius: 8px; padding: 12px; font-size: 13px; font-weight: 500; cursor: pointer; line-height: 1.4; display: inline-block;"><span>Login</span></button></div>"`;

exports[`Conditionals: Snapshot > sollte Inline Conditional dem Snapshot entsprechen 1`] = `"<div data-id="Button1" data-state="default" class="Button" style="display: inline-block; padding: 12px; border-radius: 8px; background-color: rgb(51, 51, 51);"><button data-id="Button1" data-source-line="2" class="Button" type="button" style="background-color: rgb(51, 51, 51); color: rgb(224, 224, 224); border: medium; border-radius: 8px; padding: 12px; font-size: 13px; font-weight: 500; cursor: pointer; line-height: 1.4; display: inline-block;"><span>Toggle</span></button></div>"`;
