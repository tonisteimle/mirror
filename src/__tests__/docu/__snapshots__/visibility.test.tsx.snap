// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Visibility: Snapshot > sollte Opacity dem Snapshot entsprechen 1`] = `"<div data-id="Box1" data-source-line="0" class="Box" style="display: inline-block; opacity: 0.5; background-color: rgb(59, 130, 246); padding: 16px; color: rgb(165, 165, 165);"><span>Semi-transparent</span></div>"`;

exports[`Visibility: Snapshot > sollte Visible dem Snapshot entsprechen 1`] = `"<div data-id="Box1" data-source-line="0" class="Box" style="display: inline-block; background-color: rgb(34, 197, 94); padding: 16px; color: rgb(165, 165, 165);"><span>Visible Box</span></div>"`;
