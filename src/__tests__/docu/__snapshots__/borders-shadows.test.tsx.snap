// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`Borders & Shadows: Snapshot > sollte Basic Border dem Snapshot entsprechen 1`] = `"<div data-id="Box1" data-source-line="0" class="Box" style="display: inline-block; padding: 16px; background-color: rgb(26, 26, 26); border: 2px solid rgb(59, 130, 246); color: rgb(165, 165, 165);"><span>Bordered</span></div>"`;

exports[`Borders & Shadows: Snapshot > sollte Shadow dem Snapshot entsprechen 1`] = `"<div data-id="Card1" data-source-line="0" class="Card" style="display: inline-flex; flex-direction: column; gap: 8px; padding: 24px; background-color: white; border-radius: 8px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1);"><span>Card with Shadow</span></div>"`;
