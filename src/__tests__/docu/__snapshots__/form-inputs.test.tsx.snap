exports[`Form Inputs: Snapshot > sollte Basic Input dem Snapshot entsprechen 1`] = `"<input data-id="Input1" data-source-line="0" class="Input" placeholder="Enter your name" style="background-color: rgb(26, 26, 26); color: white; border: 1px solid rgb(51, 51, 51); border-radius: 8px; padding: 12px; font-size: 13px; line-height: 1.4; font-weight: 400; min-width: 120px; display: inline-block;" type="text">"`;

exports[`Form Inputs: Snapshot > sollte Styled Form dem Snapshot entsprechen 1`] = `"<div data-id="Form1" data-source-line="0" class="Form" style="display: inline-flex; flex-direction: column; gap: 12px; padding: 16px; background-color: rgb(26, 26, 26); border-radius: 8px;"><input data-id="Input1" data-source-line="1" class="Input" placeholder="Email" style="background-color: rgb(51, 51, 51); color: white; border: medium; border-radius: 8px; padding: 12px; font-size: 13px; line-height: 1.4; font-weight: 400; min-width: 120px; display: inline-block;" type="text"><input data-id="Input2" data-source-line="2" class="Input" placeholder="Password" style="background-color: rgb(51, 51, 51); color: white; border: medium; border-radius: 8px; padding: 12px; font-size: 13px; line-height: 1.4; font-weight: 400; min-width: 120px; display: inline-block;" type="text"><button data-id="Button1" data-source-line="3" class="Button" type="button" style="background-color: rgb(59, 130, 246); color: white; border: medium; border-radius: 8px; padding: 12px; font-size: 13px; font-weight: 500; cursor: pointer; line-height: 1.4; display: inline-block;"><span>Login</span></button></div>"`;
