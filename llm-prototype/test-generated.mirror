// Generated Dropdown Component
Dropdown: ver, bg #1A1A23
  onclick-outside hide Menu
  Trigger: hor, spread, ver-center, gap 8, bg #18181B, col #E4E4E7, bor 1 #333333, rad 6, pad 8 16, shadow sm
    state hover bg #333
    state focus boc #2563EB
    state active bg #2563EB, col white
    onclick toggle Menu
    Label: col #E4E4E7, font-size 14
    ChevronIcon: col #A1A1AA
  Menu: ver, gap 4, bg #1A1A23, bor 1 #333333, rad 6, shadow sm, hidden
    keys
      escape hide Menu
      arrow-down highlight next
      arrow-up highlight prev
      enter select highlighted, hide Menu
    Item: ver-center, col #E4E4E7, pad 8 16, rad 6
      state hover bg #333
      state highlighted bg #333
      state selected bg #2563EB, col white
      onclick select, hide Menu
      onhover highlight

// Usage
Dropdown width 200
  Label "Select option"
  ChevronIcon "chevron-down"
  Menu
    - Item "Option 1"
    - Item "Option 2"
    - Item "Option 3"
