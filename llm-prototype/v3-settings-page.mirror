// Component Definitions

Header: hor, spread, ver-center, pad 12 16, bg #18181B, bor b 1 #333
  Title: col #F4F4F5, font-size 16, weight bold
  Subtitle: col #A1A1AA, font-size 12

Input: ver, gap 4
  InputLabel: col #A1A1AA, font-size 12
  InputField: bg #27272A, bor 1 #333, rad 6, pad 10 12, col #F4F4F5
    state focus bor 1 #2563EB

Button: hor, gap 8, ver-center, bg #2563EB, col white, pad 8 16, rad 6
  state hover bg #1D4ED8
  Label:

Card: ver, bg #1A1A23, rad 8, bor 1 #333
  CardHeader: hor, spread, ver-center, pad 12 16, bor b 1 #333
    CardTitle: col #F4F4F5, font-size 14, weight 600
  CardContent: pad 16, ver, gap 16

Tabs: ver, gap 0
  TabList: hor, gap 0, bor b 1 #333
    Tab: pad 12 16, col #A1A1AA, cursor pointer
      state hover col #F4F4F5
      state active col #F4F4F5, bor b 2 #2563EB
  TabPanels: pad 16
    TabPanel: hidden
      state active visible

Container: ver, gap 16

ButtonGroup: hor, gap 8

// Page

Container
  Header
    Title "Settings"
    Subtitle "Manage your preferences"
  
  Tabs
    TabList
      - Tab "Profile"
      - Tab "Security"
      - Tab "Notifications"
      - Tab "Billing"
    
    TabPanels
      - TabPanel
        state active visible
        Card
          CardTitle "Profile Settings"
          CardContent
            Input
              InputLabel "Name"
              InputField "Enter your full name"
            Input
              InputLabel "Email"
              InputField "Enter your email address"
            Input
              InputLabel "Bio"
              InputField "Tell us about yourself"
            ButtonGroup
              Button
                Label "Save Changes"
              Button
                Label "Cancel"
      
      - TabPanel
        Card
          CardTitle "Security Settings"
          CardContent
            Input
              InputLabel "Current Password"
              InputField "Enter current password"
            Input
              InputLabel "New Password"
              InputField "Enter new password"
      
      - TabPanel
        Card
          CardTitle "Notification Preferences"
          CardContent
            Input
              InputLabel "Email Notifications"
              InputField "Manage email settings"
      
      - TabPanel
        Card
          CardTitle "Billing Information"
          CardContent
            Input
              InputLabel "Billing Address"
              InputField "Enter your billing address"