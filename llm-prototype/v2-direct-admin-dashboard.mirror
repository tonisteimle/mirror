// Component Definitions
Sidebar: ver, width 240, height full, bg #18181B, pad 12
  Logo: pad 12 16, font-size 16, weight bold, col #F4F4F5
  NavSection: ver, gap 4
    NavItem: hor, gap 8, pad 8 16, rad 6, col #E4E4E7
      state hover bg #333
      state active bg #2563EB, col white
      NavIcon:
      NavLabel:

Header: hor, spread, ver-center, pad 12 16, bg #18181B, bor b 1 #333
  Title: col #F4F4F5, font-size 16, weight bold
  Subtitle: col #A1A1AA, font-size 12

StatsCard: ver, gap 4, bg #1A1A23, pad 16, rad 8
  Label: col #A1A1AA, font-size 12, uppercase
  Value: col #F4F4F5, font-size 24, weight bold
  Trend: hor, gap 4, font-size 12

Card: ver, bg #1A1A23, rad 8, bor 1 #333
  CardHeader: hor, spread, ver-center, pad 12 16, bor b 1 #333
    CardTitle: col #F4F4F5, font-size 14, weight 600
  CardContent: pad 16

DataTable: ver, bg #1A1A23, rad 8, bor 1 #333
  TableHeader: hor, bg #18181B, pad 8 16
    - TableHeaderCell: col #A1A1AA, font-size 12, weight 600
  TableBody: ver
    - TableRow: hor, pad 8 16, bor b 1 #333
      state hover bg #333
      - TableCell: col #E4E4E7, font-size 14

MainLayout: hor, gap 0
  Sidebar
    Logo "Acme"
    NavSection
      - NavItem
        NavLabel "Dashboard"
      - NavItem
        NavLabel "Users"
      - NavItem
        NavLabel "Products"
      - NavItem
        NavLabel "Orders"
      - NavItem
        NavLabel "Settings"
  MainContent: ver, flex 1, bg #09090B
    Header
      Title "Dashboard"
      Subtitle "Welcome back"
    PageContent: ver, gap 16, pad 16
      StatsGrid: grid 4, gap 16
        - StatsCard
          Label "Users"
          Value "12,345"
        - StatsCard
          Label "Revenue"
          Value "$45,678"
        - StatsCard
          Label "Orders"
          Value "1,234"
        - StatsCard
          Label "Conversion"
          Value "3.2%"
      Card
        CardHeader
          CardTitle "Recent Orders"
        CardContent
          DataTable
            TableHeader
              - TableHeaderCell "Order ID"
              - TableHeaderCell "Customer"
              - TableHeaderCell "Amount"
              - TableHeaderCell "Status"
            TableBody
              - TableRow
                - TableCell "#ORD-001"
                - TableCell "John Doe"
                - TableCell "$1,234"
                - TableCell "Completed"
              - TableRow
                - TableCell "#ORD-002"
                - TableCell "Jane Smith"
                - TableCell "$2,456"
                - TableCell "Pending"
              - TableRow
                - TableCell "#ORD-003"
                - TableCell "Bob Johnson"
                - TableCell "$3,789"
                - TableCell "Shipped"
              - TableRow
                - TableCell "#ORD-004"
                - TableCell "Alice Brown"
                - TableCell "$1,567"
                - TableCell "Completed"

// Page
MainLayout