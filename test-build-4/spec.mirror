import _components
import _tokens

SettingsPanel:
  Card w 400
    Column gap $lg.gap
      // Header
      H3 "Settings"
      
      Divider
      
      // Appearance Section
      Column gap $md.gap
        Label "APPEARANCE"
        
        Row spread
          Text "Dark Mode"
          Toggle
        
        Row spread
          Text "Theme"
          Select
            Option "Light"
            Option "Dark"
            Option "System"
      
      Divider
      
      // Notifications Section
      Column gap $md.gap
        Label "NOTIFICATIONS"
        
        Row spread
          Text "Email Notifications"
          Toggle
        
        Row spread
          Text "Push Notifications"
          Toggle
      
      Divider
      
      // Footer
      Row right, gap $sm.gap
        Button "Cancel"
        PrimaryButton "Save"