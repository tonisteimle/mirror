{
  "name": "mirror-lang",
  "version": "2.0.0-alpha.1",
  "description": "Mirror DSL compiler - UI as code",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "mirror-validate": "./dist/validator/cli.js",
    "mirror-compile": "./dist/cli.js"
  },
  "scripts": {
    "validate": "npx tsx src/validator/cli.ts",
    "build": "tsup && npm run build:studio && cp assets/mirror-defaults.css dist/ && cp assets/mirror-defaults.css studio/dist/ && cp dist/browser/index.global.js studio/dist/browser/",
    "build:studio": "tsup --config studio/tsup.config.ts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "dev:studio": "tsup src/index.ts --format iife --global-name Mirror --outDir dist/browser --watch",
    "studio": "npx serve . -p 5173",
    "test": "vitest",
    "test:browser": "npx tsx tools/test.ts",
    "test:browser:progress": "npx tsx tools/test.ts --progress --all",
    "test:browser:drag": "npx tsx tools/test.ts --drag",
    "test:browser:mirror": "npx tsx tools/test.ts --mirror",
    "test:browser:headed": "npx tsx tools/test.ts --headed",
    "test:demos": "npx tsx tools/test.ts --demo-suite=tools/test-runner/demo/scripts --pacing=instant",
    "test:demos:headed": "npx tsx tools/test.ts --demo-suite=tools/test-runner/demo/scripts --headed --pacing=video",
    "test:image": "npx tsx tools/image-to-mirror-test/cli.ts",
    "test:image:headed": "npx tsx tools/image-to-mirror-test/cli.ts --headed --verbose",
    "test:image:basic": "npx tsx tools/image-to-mirror-test/cli.ts --level=basic --verbose",
    "test:image:step0": "npx tsx tools/image-to-mirror-test/tests/step0.ts",
    "test:image:step1": "npx tsx tools/image-to-mirror-test/tests/step1.ts",
    "test:image:step2": "npx tsx tools/image-to-mirror-test/tests/step2.ts",
    "test:image:step3": "npx tsx tools/image-to-mirror-test/tests/step3.ts",
    "test:image:step4": "npx tsx tools/image-to-mirror-test/tests/step4.ts",
    "test:image:step5": "npx tsx tools/image-to-mirror-test/tests/step5.ts",
    "test:image:step6": "npx tsx tools/image-to-mirror-test/tests/step6.ts",
    "test:image:step7": "npx tsx tools/image-to-mirror-test/tests/step7.ts",
    "test:image:step8": "npx tsx tools/image-to-mirror-test/tests/step8.ts",
    "test:image:fonts": "npx tsx tools/image-to-mirror-test/font-recognition/calibrate.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 1500",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "generate": "npx tsx scripts/generate-from-schema.ts",
    "generate:check": "npx tsx scripts/generate-from-schema.ts --check",
    "generate:claude": "npx tsx scripts/generate-claude-tutorial.ts",
    "build:tutorial": "npx tsx scripts/generate-tutorial.ts",
    "tutorial:extract": "npx tsx tools/extract-tutorial-tests.ts",
    "tutorial:generate": "npx tsx tools/generate-tutorial-tests.ts",
    "tutorial:sync": "npm run tutorial:extract && npm run tutorial:generate",
    "test:browser:tutorial": "npx tsx tools/test.ts --category=tutorial --progress",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@anthropic-ai/sdk": "^0.88.0",
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.9",
    "@atlaskit/pragmatic-drag-and-drop-hitbox": "^1.1.0",
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/language": "^6.12.1",
    "@codemirror/lint": "^6.9.3",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.12",
    "@lezer/highlight": "^1.2.3",
    "@zag-js/checkbox": "^1.37.0",
    "@zag-js/core": "^1.37.0",
    "@zag-js/date-picker": "^1.37.0",
    "@zag-js/dialog": "^1.37.0",
    "@zag-js/dom-query": "^1.37.0",
    "@zag-js/menu": "^1.39.1",
    "@zag-js/radio-group": "^1.37.0",
    "@zag-js/select": "^1.37.0",
    "@zag-js/slider": "^1.37.0",
    "@zag-js/splitter": "^1.39.1",
    "@zag-js/switch": "^1.37.0",
    "@zag-js/tabs": "^1.37.0",
    "@zag-js/tooltip": "^1.37.0",
    "@zag-js/tree-view": "^1.39.1",
    "@zag-js/vanilla": "^1.37.0",
    "fdir": "^6.5.0",
    "focus-trap": "^8.0.1",
    "motion": "^12.38.0",
    "tabbable": "^6.4.0",
    "tom-select": "^2.5.2"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.27.3",
    "eslint": "^10.2.0",
    "fast-check": "^4.7.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jimp": "^1.6.1",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "serve": "^14.2.6",
    "tesseract.js": "^7.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4",
    "ws": "^8.20.0"
  },
  "keywords": [
    "mirror",
    "dsl",
    "ui",
    "compiler",
    "parser"
  ],
  "license": "MIT"
}
