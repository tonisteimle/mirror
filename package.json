{
  "name": "designer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:embed": "vite build --config vite.embed.config.ts",
    "build:analyze": "ANALYZE=true npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:browser": "vitest --config vitest.browser.config.ts",
    "test:browser:run": "vitest run --config vitest.browser.config.ts",
    "bench": "vitest bench",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test",
    "test:llm": "npx tsx src/__tests__/llm-e2e/run-tests.ts",
    "test:llm:smoke": "npx tsx src/__tests__/llm-e2e/run-tests.ts --smoke",
    "test:llm:mod": "npx tsx src/__tests__/llm-e2e/run-modification-tests.ts",
    "test:llm:mod:smoke": "npx tsx src/__tests__/llm-e2e/run-modification-tests.ts --smoke",
    "test:visual": "npm run build:embed && cp dist/embed/mirror-editor.js docs/ && npx tsx scripts/generate-docu.ts && npx tsx scripts/generate-reference.ts && open docs/tutorial.html",
    "docs:update": "npm run build:embed && cp dist/embed/mirror-editor.js docs/",
    "docs:generate": "npx tsx scripts/generate-docu.ts && npx tsx scripts/generate-reference.ts",
    "llm:record": "npx tsx scripts/llm-record.ts",
    "llm:record:all": "npx tsx scripts/llm-record.ts --pipeline=nl-translation && npx tsx scripts/llm-record.ts --pipeline=generation && npx tsx scripts/llm-record.ts --pipeline=syntax-correction && npx tsx scripts/llm-record.ts --pipeline=js-builder",
    "llm:eval": "vitest run src/__tests__/llm-evaluation/suites/",
    "llm:eval:watch": "vitest src/__tests__/llm-evaluation/suites/",
    "llm:prompts": "npx tsx scripts/show-prompts.ts",
    "llm:review": "npx tsx scripts/review-fixtures.ts",
    "llm:compare": "npx tsx scripts/compare-models.ts",
    "llm:regression": "npx tsx scripts/check-regression.ts",
    "llm:regression:strict": "npx tsx scripts/check-regression.ts --strict",
    "llm:baseline:update": "npx tsx scripts/check-regression.ts --update",
    "llm:coverage": "npx tsx scripts/analyze-coverage.ts",
    "llm:coverage:verbose": "npx tsx scripts/analyze-coverage.ts --verbose",
    "llm:reprocess": "npx tsx scripts/reprocess-fixtures.ts",
    "ci": "npm run lint && npm run test:run && npm run llm:eval"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.1",
    "@codemirror/lint": "^6.9.3",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.12",
    "@lezer/highlight": "^1.2.3",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-toolbar": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.76.0",
    "@eslint/js": "^9.39.1",
    "@playwright/mcp": "^0.0.64",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "dotenv": "^17.2.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fast-check": "^4.5.3",
    "globals": "^16.5.0",
    "jsdom": "^28.0.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
