    "code": "let items = []
let filteredItems = []

search.oninput = () => {
    const query = search.value.toLowerCase()
    filteredItems = items.filter(i =>
        i.name.toLowerCase().includes(query)
    )
    status.text = \`\${filteredItems.length} Ergebnisse\`
    update()
}

fetch('/api/items')
    .then(r => r.json())
    .then(data => {
        items = data
        filteredItems = data
        update()
    })",
    "type": "JavaScript",
  },
  "type": "Program",
}
`;

