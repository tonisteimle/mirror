      Frame hor, spread, ver-center, pad 8 20, bg $bg.panel, bor t 1 $border
        Frame hor, gap 16
          Frame hor, gap 4
            Text "Showing", fs 10, col $muted
            Text "12 of 18", fs 10, col $secondary
            Text "positions", fs 10, col $muted
          Frame hor, gap 4
            Text "Last sync:", fs 10, col $muted
            Text "10:34:22 CET", fs 10, col $secondary
        Text "Data provided by Refinitiv · Prices delayed 15 min", fs 10, col $muted
