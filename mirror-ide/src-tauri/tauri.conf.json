{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mirror IDE",
  "version": "0.1.0",
  "identifier": "com.mirror.ide",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5500/studio",
    "beforeBuildCommand": "",
    "frontendDist": "../../studio"
  },
  "app": {
    "windows": [
      {
        "title": "Mirror IDE",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Mirror IDE - DSL for rapid UI prototyping",
    "longDescription": "A desktop IDE for Mirror DSL that uses Claude CLI to generate UI from natural language descriptions."
  }
}
