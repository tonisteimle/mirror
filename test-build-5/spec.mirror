import _components

TodoApp:
  Container w full, h full, maxw 500, center
    Header hor, spread, ver-center, pad bottom $md.pad
      H2 "My Tasks"
      PrimaryButton
        Icon plus
        Text "Add"
        onclick: show #NewTaskInput, focus #TaskInput
    
    Box #NewTaskInput hidden, pad bottom $md.pad
      Row
        Input #TaskInput placeholder "What needs to be done?", grow
          onkeydown enter: call addTask
        PrimaryButton "Add"
          onclick: call addTask
    
    Box #TaskList gap $sm.gap, grow, scroll
      TaskItem #task-template hidden
        Row spread
          Row
            Checkbox #task-checkbox
              onchange: toggle .completed on parent TaskItem
            Text #task-text "Task text"
              state completed
                col $text.muted.col
                style text-decoration line-through
          IconButton
            Icon trash
            onclick: hide parent TaskItem, call updateCount
    
    Footer hor, spread, ver-center, pad top $md.pad, bor top 1 $border.subtle.col
      TextSmall #TaskCount "0 tasks remaining"
      GhostButton "Clear completed"
        onclick: call clearCompleted

TaskItem as ListItem:
  state completed
    opacity 0.6